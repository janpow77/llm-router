+# Cache fuer CF-Access-Header — Env-Vars werden einmal beim ersten Failover
+# gelesen. SIGHUP/Restart laedt sie neu. Wenn beide Env-Vars fehlen, liefert
+# der Helper {} und der Fallback-Request laeuft ohne Cloudflare-Access-Header
+# (sinnvoll fuer reine Internal-Tunnels ohne Access-Policy).
+_cf_access_cache: dict[str, str] | None = None
+
+
+def _cf_access_headers() -> dict[str, str]:
+    """Liest CF_ACCESS_CLIENT_ID / CF_ACCESS_CLIENT_SECRET aus dem Env.
+
+    Diese beiden Header (CF-Access-Client-Id / CF-Access-Client-Secret) erlauben
+    einem Service-Token, das Cloudflare-Access-Gate vor ``fallback_url`` zu
+    passieren — siehe ``docs/fallback-cloudflare.md`` Schritt 5/6.
+    """
+    global _cf_access_cache
+    if _cf_access_cache is not None:
+        return _cf_access_cache
+    client_id = os.environ.get("CF_ACCESS_CLIENT_ID", "").strip()
+    client_secret = os.environ.get("CF_ACCESS_CLIENT_SECRET", "").strip()
+    headers: dict[str, str] = {}
+    if client_id and client_secret:
+        headers["CF-Access-Client-Id"] = client_id
+        headers["CF-Access-Client-Secret"] = client_secret
+        log.info("cf-access: service-token loaded (client_id=%s***)", client_id[:6])
+    else:
+        log.debug("cf-access: no service-token in env (CF_ACCESS_CLIENT_ID/SECRET missing)")
+    _cf_access_cache = headers
+    return headers
+
+
+def build_fallback_url(spoke: SpokeConfig, upstream_path: str, query: str) -> str | None:
+    """Liefert die fuer den Failover-Versuch zu verwendende URL.
+
+    Returns None, wenn der Spoke keinen Fallback hinterlegt hat.
+    """
+    if not getattr(spoke, "fallback_url", None):
+        return None
+    base = spoke.fallback_url.rstrip("/")  # type: ignore[union-attr]
+    url = f"{base}{upstream_path}"
+    if query:
+        url = f"{url}?{query}"
+    return url
+

